# ============================================================
# PerfTuner / Auriga — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your own values.
#   cp .env.example .env
# The .env file is listed in .gitignore and must NOT be committed.
# ============================================================

# ------------------------------------------------------------------
# DeepSeek LLM API (https://platform.deepseek.com)
# Used by: param-config agent and tx-schedule-v1/llm_extract.py
# ------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Model name — any DeepSeek chat model; paper used DeepSeek-V3
DEEPSEEK_MODEL=deepseek-chat

# ------------------------------------------------------------------
# Config server (param-config subsystem)
# The local_config_server/server.py must be running before the agent.
# Default port is 8080 on localhost.
# ------------------------------------------------------------------
CONFIG_SERVER_URL=http://127.0.0.1:8080

# ------------------------------------------------------------------
# Fabric peer SSH target (tx-schedule-v1 world-state sampling)
# Used by WorldStateSampler for offline histogram / reservoir builds.
# Format: user@hostname-or-ip
# Only required when running live Fabric experiments.
# ------------------------------------------------------------------
FABRIC_PEER_SSH=<user@peer-host>
